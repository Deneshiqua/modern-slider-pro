{
  "name": "modern-slider-pro",
  "version": "0.7.0",
  "description": "Visual drag-and-drop slider builder and runner for React — canvas editor, alignment, rulers, animations, and embeddable playback.",
  "author": "deneshiqua",
  "repository": {
    "type": "git",
    "url": "https://github.com/deneshiqua/modern-slider-pro"
  },
