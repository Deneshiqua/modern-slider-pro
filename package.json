    "url": "https://github.com/deneshiqua/modern-slider-pro/issues"
  },
  "type": "module",
  "packageManager": "pnpm@8.10.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/style.css"
  ],
  "keywords": [
    "slider",
    "carousel",
    "editor",
    "builder",
    "react",
    "drag-and-drop",
    "framer-motion",
    "visual-editor",
    "animation"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "pnpm exec vite",
    "dev:fresh": "pnpm exec vite --force",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "prepublishOnly": "pnpm build:lib",
    "lint": "eslint --quiet ./src",
    "preview": "vite preview"
  },
